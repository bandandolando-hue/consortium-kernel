{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://consortium.lowneon/schemas/contract-pack.v1.json",
  "title": "Consortium Contract Pack (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "feature",
    "goal",
    "constraints",
    "data",
    "api",
    "client",
    "ui",
    "observability",
    "acceptance_tests",
    "definition_of_done"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0" },

    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "slug", "owner_role"],
      "properties": {
        "name": { "type": "string", "minLength": 3 },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*$",
          "description": "Dot-separated feature id, e.g. decisions.getById"
        },
        "owner_role": {
          "type": "string",
          "enum": ["ARCHIVIST", "ARCHITECT", "BUILDER", "UX", "GATEKEEPER"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "goal": { "type": "string", "minLength": 5 },

    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },

    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tables", "constraints", "access_control"],
      "properties": {
        "tables": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/tableSpec" }
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/dbConstraint" }
        },
        "access_control": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "rules"],
          "properties": {
            "model": {
              "type": "string",
              "enum": ["cloudflare_access", "supabase_rls", "custom"]
            },
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 3 }
            }
          }
        }
      }
    },

    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoints", "error_model"],
      "properties": {
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/endpointSpec" }
        },
        "error_model": { "$ref": "#/$defs/errorModel" }
      }
    },

    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["functions", "timeouts", "retries"],
      "properties": {
        "functions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clientFunction" }
        },
        "timeouts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default_ms"],
          "properties": {
            "default_ms": { "type": "integer", "minimum": 1000, "maximum": 60000 }
          }
        },
        "retries": {
          "type": "object",
          "additionalProperties": false,
          "required": ["network_max_attempts", "retry_on_statuses"],
          "properties": {
            "network_max_attempts": { "type": "integer", "minimum": 0, "maximum": 5 },
            "retry_on_statuses": {
              "type": "array",
              "items": { "type": "integer", "minimum": 100, "maximum": 599 },
              "uniqueItems": true
            }
          }
        }
      }
    },

    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["states", "rendering_rules"],
      "properties": {
        "states": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "enum": ["idle", "loading", "success", "empty", "not_found", "error"]
          },
          "uniqueItems": true
        },
        "rendering_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/uiRule" }
        }
      }
    },

    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "server_logging", "client_debug"],
      "properties": {
        "request_id": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required_on_success", "required_on_error"],
          "properties": {
            "required_on_success": { "type": "boolean", "const": true },
            "required_on_error": { "type": "boolean", "const": true }
          }
        },
        "server_logging": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runs_table", "fields"],
          "properties": {
            "runs_table": { "type": "string", "minLength": 1 },
            "fields": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "client_debug": {
          "type": "object",
          "additionalProperties": false,
          "required": ["show_request_id", "copy_debug_button"],
          "properties": {
            "show_request_id": { "type": "boolean" },
            "copy_debug_button": { "type": "boolean" }
          }
        }
      }
    },

    "acceptance_tests": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/acceptanceTest" }
    },

    "definition_of_done": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },

  "$defs": {
    "tableSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "columns"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/columnSpec" }
        },
        "notes": { "type": "string" }
      }
    },

    "columnSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "primary_key": { "type": "boolean" },
        "nullable": { "type": "boolean" },
        "default": { "type": ["string", "number", "boolean", "null"] },
        "references": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "column"],
          "properties": {
            "table": { "type": "string", "minLength": 1 },
            "column": { "type": "string", "minLength": 1 }
          }
        }
      }
    },

    "dbConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "detail"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["foreign_key", "unique", "check", "index", "other"]
        },
        "detail": { "type": "string", "minLength": 3 }
      }
    },

    "endpointSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path", "auth", "request", "responses"],
      "properties": {
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "pattern": "^/" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "strategy"],
          "properties": {
            "required": { "type": "boolean" },
            "strategy": {
              "type": "string",
              "enum": ["cloudflare_access", "service_token", "bearer", "none", "custom"]
            },
            "notes": { "type": "string" }
          }
        },
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path_params", "query_params", "headers", "body"],
          "properties": {
            "path_params": { "$ref": "#/$defs/paramsSpec" },
            "query_params": { "$ref": "#/$defs/paramsSpec" },
            "headers": { "$ref": "#/$defs/paramsSpec" },
            "body": {
              "type": ["object", "null"],
              "description": "JSON schema for body or null if none"
            }
          }
        },
        "responses": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/responseSpec" }
        }
      }
    },

    "paramsSpec": {
      "type": "array",
      "items": { "$ref": "#/$defs/param" }
    },

    "param": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },

    "responseSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "body"],
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "body": {
          "type": ["object", "null"],
          "description": "JSON schema for response body or null if none"
        },
        "notes": { "type": "string" }
      }
    },

    "errorModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "required_fields"],
      "properties": {
        "shape": {
          "type": "object",
          "additionalProperties": true,
          "description": "Schema snippet describing standard error shape"
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "clientFunction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "endpoint", "returns"],
      "properties": {
        "name": { "type": "string", "minLength": 3 },
        "endpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "path"],
          "properties": {
            "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
            "path": { "type": "string", "pattern": "^/" }
          }
        },
        "returns": { "type": "string", "minLength": 2 },
        "notes": { "type": "string" }
      }
    },

    "uiRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "renders"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["idle", "loading", "success", "empty", "not_found", "error"]
        },
        "renders": { "type": "string", "minLength": 3 }
      }
    },

    "acceptanceTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "statement"],
      "properties": {
        "id": { "type": "string", "pattern": "^AT-[0-9]{3,}$" },
        "type": { "type": "string", "enum": ["api", "db", "ui", "integration"] },
        "statement": { "type": "string", "minLength": 5 }
      }
    }
  }
}