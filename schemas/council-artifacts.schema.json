{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://consortium.lowneon/schemas/council-artifacts.v1.json",
  "title": "Council Artifacts (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["interaction_model", "selected_specialists", "stages", "specialist_stances", "quorum", "decision_card"],
  "properties": {
    "interaction_model": {
      "type": "string",
      "enum": ["tiered"]
    },
    "selected_specialists": {
      "type": "array",
      "items": { "type": "object" }
    },
    "specialist_stances": {
      "type": "array",
      "items": { "$ref": "#/$defs/specialistStance" }
    },
    "stages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/proposeStage" },
          { "$ref": "#/$defs/reviewStage" },
          { "$ref": "#/$defs/finalStage" }
        ]
      }
    },
    "quorum": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/seatStance" }
    },
    "decision_card": { "$ref": "#/$defs/decisionCard" }
  },
  "$defs": {
    "requiredChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from_role", "type", "statement"],
      "properties": {
        "id": { "type": "string", "pattern": "^RC-[0-9]{3,}$" },
        "from_role": { "type": "string", "minLength": 2 },
        "type": {
          "type": "string",
          "enum": ["artifact", "tone", "security", "data", "api", "ui", "other"]
        },
        "statement": { "type": "string", "minLength": 3 }
      }
    },
    "specialistStance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "stance", "risks", "asks", "proposed_changes"],
      "properties": {
        "role": { "type": "string", "minLength": 2 },
        "stance": { "type": "string", "minLength": 3 },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        },
        "asks": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        },
        "proposed_changes": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        }
      }
    },
    "proposeStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "specialists", "stances"],
      "properties": {
        "stage": { "const": "propose" },
        "specialists": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        },
        "stances": {
          "type": "array",
          "items": { "$ref": "#/$defs/specialistStance" }
        }
      }
    },
    "reviewStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "specialists", "stances", "required_changes"],
      "properties": {
        "stage": { "const": "review" },
        "specialists": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        },
        "stances": {
          "type": "array",
          "items": { "$ref": "#/$defs/specialistStance" }
        },
        "required_changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredChange" }
        }
      }
    },
    "finalStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "specialists", "satisfies_required_changes", "decision_card"],
      "properties": {
        "stage": { "const": "final" },
        "specialists": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "const": "CAPTAIN" }
        },
        "satisfies_required_changes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^RC-[0-9]{3,}$" }
        },
        "decision_card": { "$ref": "#/$defs/decisionCard" }
      }
    },
    "seatRole": {
      "type": "string",
      "enum": ["ARCHIVIST", "ARCHITECT", "BUILDER", "UX", "GATEKEEPER"]
    },
    "seatStance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "stance", "risks", "asks", "proposed_changes"],
      "properties": {
        "role": { "$ref": "#/$defs/seatRole" },
        "stance": { "type": "string", "minLength": 3 },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        },
        "asks": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        },
        "proposed_changes": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        }
      }
    },
    "decisionCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "constraints",
        "plan",
        "acceptance_tests",
        "definition_of_done"
      ],
      "properties": {
        "goal": { "type": "string", "minLength": 3 },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        },
        "plan": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "acceptance_tests": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        },
        "definition_of_done": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "minItems": 1
        }
      }
    }
  }
}
