{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://consortium.lowneon/schemas/specialists.registry.schema.v1.json",
  "title": "Specialists Registry (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "specialists"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "specialists": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/specialist" }
    }
  },
  "$defs": {
    "specialist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "best_for",
        "output_type",
        "selection_rule",
        "tier",
        "stance_schema"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
        "name": { "type": "string", "minLength": 3 },
        "best_for": { "type": "string", "minLength": 3 },
        "output_type": { "type": "string", "minLength": 3 },
        "selection_rule": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "enum": ["always", "keyword"] },
            "allow_disable": { "type": "boolean" },
            "keywords": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 2 }
            }
          },
          "allOf": [
            {
              "if": { "properties": { "kind": { "const": "keyword" } } },
              "then": { "required": ["keywords"] }
            }
          ]
        },
        "tier": { "type": "string", "enum": ["propose", "review"] },
        "stance_schema": { "type": "string", "minLength": 3 }
      }
    }
  }
}
